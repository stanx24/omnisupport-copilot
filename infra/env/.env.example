ANTHROPIC_API_KEY=

# PostgreSQL
POSTGRES_USER=omni
POSTGRES_PASSWORD=omnipass
POSTGRES_DB=omnisupport
# Host port for local DB clients such as DataGrip. Container services still use postgres:5432.
POSTGRES_HOST_PORT=15432

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Release / seed
RELEASE_ID=dev-local
SEED_TICKET_COUNT=500

# Week04 Lakehouse / Iceberg
ICEBERG_CATALOG_NAME=omni
ICEBERG_CATALOG_TYPE=sql
ICEBERG_CATALOG_URI=postgresql+psycopg2://omni:omnipass@postgres:5432/omnisupport
ICEBERG_WAREHOUSE=s3://omni-lakehouse/warehouse
ICEBERG_NAMESPACE_BRONZE=bronze
ICEBERG_NAMESPACE_SILVER=silver
ICEBERG_FILE_IO=pyiceberg.io.pyarrow.PyArrowFileIO

# S3-compatible MinIO for PyIceberg FileIO
ICEBERG_S3_ENDPOINT=http://minio:9000
ICEBERG_S3_ACCESS_KEY_ID=minioadmin
ICEBERG_S3_SECRET_ACCESS_KEY=minioadmin
ICEBERG_S3_REGION=us-east-1
ICEBERG_S3_PATH_STYLE_ACCESS=true

# Week04 run metadata
WEEK04_DATA_RELEASE_ID=week04-dev-local
WEEK04_INGEST_BATCH_ID=week04-smoke
WEEK04_REPORT_DIR=reports/week04

# Week05 Analytics Engineering / dbt
DBT_TARGET=dev
DBT_POSTGRES_HOST=postgres
DBT_POSTGRES_PORT=5432
WEEK05_DATA_RELEASE_ID=week05-dev-local
WEEK05_REPORT_DIR=reports/week05
METRIC_REGISTRY_PATH=/workspace/analytics/metric_registry_v1.yml

# Week06 Data Factory / Dagster Assets
WEEK06_PROJECT_ROOT=/workspace
WEEK06_DATA_RELEASE_ID=week06-dev-local
WEEK06_REPORT_DIR=reports/week06
WEEK06_PARTITION_START_DATE=2026-03-01
WEEK06_DEFAULT_PARTITION=2026-04-17
WEEK06_TICKET_SEED_PATH=data/canonization/tickets/tickets-seed-001.jsonl
WEEK06_INGEST_DRY_RUN=true
WEEK06_INGEST_LIMIT=
WEEK06_OPERATOR=student-devbox
WEEK06_WEEK04_REPORT_PATH=reports/week04/materialization_report.json
WEEK06_WEEK05_RUN_RESULTS_PATH=analytics/target/run_results.json

# Week07 Parse / Normalize
WEEK07_MANIFEST_PATH=data/seed_manifests/manifest_workspace_helpcenter_v1.json
WEEK07_DATA_RELEASE_ID=week07-dev-local
WEEK07_ARTIFACTS_DIR=artifacts/week07
WEEK07_REPORT_DIR=reports/week07
WEEK07_PARSER=auto
WEEK07_CHUNK_STRATEGY_VERSION=section_aware_v1
WEEK07_PARSE_DRY_RUN=true
